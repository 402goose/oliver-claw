{
  "meta": {
    "lastTouchedVersion": "2026.5.11"
  },
  "memory": {
    "backend": "builtin"
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "https://oliver-claw.up.railway.app",
        "https://agentic-jack.up.railway.app",
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ]
    }
  },
  "mcp": {
    "servers": {
      "tenet-context": {
        "command": "tenet-context-hub-mcp",
        "args": [],
        "cwd": "/data/tenet",
        "env": {
          "TENET_HOME": "/data/tenet"
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.5",
        "fallbacks": [
          "anthropic/claude-sonnet-4-6",
          "openrouter/anthropic/claude-sonnet-4.6",
          "openrouter/meta-llama/llama-3.3-70b-instruct:free"
        ]
      },
      "heartbeat": {
        "every": "4h",
        "model": "openrouter/meta-llama/llama-3.3-70b-instruct:free",
        "prompt": "Read HEARTBEAT.md if present. If nothing needs attention, reply HEARTBEAT_OK only."
      },
      "thinkingDefault": "off",
      "bootstrapMaxChars": 25000,
      "models": {
        "openrouter/anthropic/claude-sonnet-4.6": {
          "alias": "sonnet46",
          "params": {
            "cacheRetention": "long",
            "maxTokens": 4000
          }
        },
        "openrouter/anthropic/claude-opus-4.7": {
          "alias": "opus",
          "params": {
            "cacheRetention": "long",
            "maxTokens": 4000
          }
        },
        "openrouter/anthropic/claude-opus-4.6": {
          "alias": "opus46",
          "params": {
            "cacheRetention": "long",
            "maxTokens": 4000
          }
        },
        "openrouter/meta-llama/llama-3.3-70b-instruct:free": {
          "alias": "llama70free",
          "params": {
            "maxTokens": 2000
          }
        },
        "anthropic/claude-sonnet-4-6": {
          "alias": "sonnet46",
          "params": {
            "cacheRetention": "long",
            "maxTokens": 4000
          }
        },
        "anthropic/claude-opus-4-7": {
          "alias": "opus47",
          "params": {
            "cacheRetention": "long",
            "maxTokens": 4000
          }
        },
        "openai/gpt-5.5": {
          "alias": "gpt55",
          "params": {
            "maxTokens": 4000
          }
        }
      },
      "workspace": "/data/workspace",
      "memorySearch": {
        "enabled": true
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "compaction": {
        "mode": "safeguard",
        "maxHistoryShare": 0.4,
        "recentTurnsPreserve": 4,
        "qualityGuard": {
          "enabled": true,
          "maxRetries": 1
        },
        "postIndexSync": "async",
        "model": "anthropic/claude-sonnet-4-6",
        "memoryFlush": {
          "enabled": true,
          "forceFlushTranscriptBytes": "2mb"
        }
      },
      "elevatedDefault": "full",
      "maxConcurrent": 4
    },
    "list": [
      {
        "id": "oliver",
        "default": true,
        "workspace": "/data/workspace/oliver",
        "identity": {
          "name": "Oliver",
          "emoji": "\ud83d\ude80"
        },
        "groupChat": {
          "mentionPatterns": [
            "@oliver",
            "@Oliver_jbot",
            "what would oliver think",
            "oliver's lens",
            "oliver pov",
            "oliver,",
            "oliver:",
            "oliver?",
            "oliver.",
            "Oliver,",
            "Oliver:",
            "Oliver?",
            "Oliver.",
            " oliver ",
            " Oliver ",
            "oliver ",
            "Oliver ",
            "@agentic_jackbot",
            "@deehock_bot",
            "jack says",
            "jack asks",
            "dee says",
            "dee asks",
            "you all",
            "y'all",
            "yall",
            "fellas",
            "agents",
            "team",
            "team,",
            "team:",
            "everyone",
            "all of you",
            "what do you all",
            "what do agents",
            "@agents",
            "@all"
          ]
        }
      }
    ]
  },
  "tools": {
    "exec": {
      "security": "full"
    },
    "web": {
      "search": {
        "enabled": true
      }
    },
    "media": {
      "image": {
        "enabled": false
      },
      "video": {
        "enabled": false,
        "maxBytes": 20971520,
        "echoTranscript": true,
        "timeoutSeconds": 120,
        "models": [
          {
            "provider": "openai",
            "model": "google/gemini-2.0-flash-exp",
            "baseUrl": "https://openrouter.ai/api/v1"
          }
        ],
        "request": {
          "auth": {
            "mode": "authorization-bearer",
            "token": "${OPENROUTER_API_KEY}"
          }
        }
      },
      "audio": {
        "enabled": true,
        "maxBytes": 26214400,
        "echoTranscript": true,
        "timeoutSeconds": 60,
        "models": [
          {
            "provider": "openai",
            "model": "whisper-1",
            "baseUrl": "https://genai-api.visa.com/v1"
          }
        ],
        "request": {
          "auth": {
            "mode": "authorization-bearer",
            "token": "${OPENAI_API_KEY}"
          }
        }
      }
    },
